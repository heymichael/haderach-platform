{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "hosting/public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "X-Robots-Tag",
            "value": "noindex, nofollow, noarchive"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/agent/api/**",
        "run": {
          "serviceId": "agent-api",
          "region": "us-central1"
        }
      },
      {
        "source": "/vendors/api/**",
        "run": {
          "serviceId": "vendors-api",
          "region": "us-central1"
        }
      },
      {
        "source": "/stocks/api/**",
        "run": {
          "serviceId": "stocks-api",
          "region": "us-central1"
        }
      },
      {
        "source": "/admin/system/**",
        "destination": "/admin/system/index.html"
      },
      {
        "source": "/admin/vendors/**",
        "destination": "/admin/vendors/index.html"
      },
      {
        "source": "/admin{,/}",
        "destination": "/index.html"
      },
      {
        "source": "/",
        "destination": "/index.html"
      }
    ]
  }
}
